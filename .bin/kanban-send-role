#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "$0")" && pwd)/kanban"

usage() {
  cat <<'EOF'
Usage:
  kanban send-role <role> <message>

Examples:
  kanban send-role manager "/compact"
  kanban send-role manager "Do your periodic healthcheck now."
EOF
}

role="${1:-}"
shift || true

if [[ "$role" == "--help" || "$role" == "-h" ]]; then
  usage
  exit 0
fi

if [[ -z "$role" || $# -eq 0 ]]; then
  usage
  exit 1
fi

require_project_context
require_cmd tmux

message="$*"
pane_id="$(find_role_pane "$role")"

tmux send-keys -t "$pane_id" -l "$message"
tmux send-keys -t "$pane_id" Enter

echo "sent $role"
