#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "$0")" && pwd)/kanban"

usage() {
  cat <<'EOF'
Usage:
  kanban recover

Run the one-off non-interactive recovery agent for the current project.
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

require_project_context
require_cmd git pi
ensure_runtime_dirs

LIST_ROLES_CMD="$(kanban_subcommand_path list-roles)"

cd "$PROJECT_ROOT"

checkpoint_ref="$(latest_checkpoint_ref || true)"
context_file="$RECOVERY_DIR/context.md"
report_file="$RECOVERY_DIR/last-recovery.md"
reentry_file="$RECOVERY_DIR/reentry.md"
recovery_session_file="$(session_file_for_role recovery)"
recovery_timeout_seconds="${PI_BACKBONE_RECOVERY_TIMEOUT_SECONDS:-900}"
export KANBAN_LOG_FILE="$LOG_DIR/recover.log"

archive_session_file recovery

{
  echo '# Recovery context'
  echo
  echo "- Timestamp: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  echo "- Project root: $PROJECT_ROOT"
  echo "- Project name: $PROJECT_NAME"
  echo "- Branch: $(git branch --show-current 2>/dev/null || echo detached)"
  echo "- HEAD: $(git rev-parse HEAD)"
  echo "- Last known good ref: ${checkpoint_ref:-none}"
  echo
  echo '## Git status'
  echo '```text'
  git status --short --branch
  echo '```'
  echo
  echo '## Recent checkpoint tags'
  echo '```text'
  git for-each-ref --sort=-creatordate --format='%(refname:short) %(objectname:short) %(subject)' 'refs/tags/kanban/*' | head -n 20
  echo '```'
  echo
  echo '## Current role panes'
  echo '```text'
  if [[ -f "$BACKBONE_ENV_FILE" ]]; then
    "$LIST_ROLES_CMD" || true
  else
    echo 'backbone env file missing'
  fi
  echo '```'
  echo
  echo '## Kanban lanes'
  for lane in 0-open 1-to_refine 2-planned 3-in_progress 4-in_review 5-done; do
    echo
    echo "### $lane"
    find "$KANBAN_DIR/$lane" -maxdepth 1 -type f | sort | sed "s#^$PROJECT_ROOT/##"
  done
} > "$context_file"

recovery_prompt="Read .kanban/README.md, .kanban/roles/recovery.md, and .kanban/runtime/recovery/context.md. You are running as a one-off recovery agent after a hard reset. Stabilize the repo to the safest understandable re-entry point. Prefer the last known good checkpoint tag if reset is needed. Do not start tmux panes. Do not continue feature work. Write .kanban/runtime/recovery/last-recovery.md and .kanban/runtime/recovery/reentry.md before you finish."
cmd=(pi -p --session "$recovery_session_file")

if [[ -n "${PI_BACKBONE_RECOVERY_PROVIDER:-}" ]]; then
  cmd+=(--provider "$PI_BACKBONE_RECOVERY_PROVIDER")
fi

if [[ -n "${PI_BACKBONE_RECOVERY_MODEL:-}" ]]; then
  cmd+=(--model "$PI_BACKBONE_RECOVERY_MODEL")
fi

cmd+=("@.kanban/README.md" "@.kanban/roles/recovery.md" "@$(relative_to_project "$context_file")" "$recovery_prompt")

if run_with_timeout "$recovery_timeout_seconds" "${cmd[@]}"; then
  if [[ ! -f "$report_file" ]]; then
    cat > "$report_file" <<EOF
# Recovery report

Recovery completed without writing a detailed report.

- Timestamp: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
- Checkpoint ref considered: ${checkpoint_ref:-none}
EOF
  fi

  if [[ ! -f "$reentry_file" ]]; then
    cat > "$reentry_file" <<EOF
# Manager re-entry note

Recovery completed.

The next manager should rebuild context from ".kanban/", git state, and the current tmux window.
EOF
  fi

  exit 0
fi

if [[ -n "$checkpoint_ref" ]]; then
  log "recovery pi run failed; falling back to deterministic reset to $checkpoint_ref"
  git reset --hard "$checkpoint_ref"
  git clean -fd

  cat > "$report_file" <<EOF
# Recovery report

The one-off pi recovery run failed, so a deterministic fallback recovery was applied.

- Timestamp: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
- Reset target: $checkpoint_ref
- Actions:
  - git reset --hard $checkpoint_ref
  - git clean -fd
EOF

  cat > "$reentry_file" <<EOF
# Manager re-entry note

Recovery used the deterministic fallback path.

Resume from the restored checkpoint:

- checkpoint: $checkpoint_ref

The next manager should read ".kanban/", inspect active panes, and resume orchestration from the restored repository state.
EOF

  exit 0
fi

log 'recovery failed and no checkpoint tag was available'
exit 1
