#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "$0")" && pwd)/kanban"

usage() {
  cat <<'EOF'
Usage:
  kanban checkpoint-ticket <path-to-ticket>
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

require_project_context
require_cmd git
ensure_runtime_dirs

ticket_path="${1:-}"
if [[ -z "$ticket_path" ]]; then
  usage
  exit 1
fi

if ! ticket_path="$(resolve_existing_project_file "$ticket_path")"; then
  echo "ticket not found: $ticket_path" >&2
  exit 1
fi

cd "$PROJECT_ROOT"

relative_ticket="$(relative_to_project "$ticket_path")"
ticket_id="$(ticket_id_from_file "$ticket_path")"
ticket_title="$(ticket_title_from_file "$ticket_path")"

if [[ -z "$ticket_id" ]]; then
  echo "could not read ticket id from: $ticket_path" >&2
  exit 1
fi

if [[ -z "$ticket_title" ]]; then
  ticket_title="$ticket_id"
fi

if [[ -n "$(git status --porcelain --untracked-files=all)" ]]; then
  git add -A
  git commit -m "checkpoint: ${ticket_id} done - ${ticket_title}"
fi

commit_ref="$(git rev-parse HEAD)"
timestamp="$(date -u +"%Y%m%dT%H%M%SZ")"
history_tag="kanban/${ticket_id}-done-${timestamp}"

git tag -a "$history_tag" -m "Done ${ticket_id}: ${ticket_title}" "$commit_ref"
git tag -fa kanban/last-known-good -m "Last known good after ${ticket_id}: ${ticket_title}" "$commit_ref"

{
  printf 'ticket=%q\n' "$relative_ticket"
  printf 'ticket_id=%q\n' "$ticket_id"
  printf 'ticket_title=%q\n' "$ticket_title"
  printf 'commit=%q\n' "$commit_ref"
  printf 'history_tag=%q\n' "$history_tag"
  printf 'last_known_good=%q\n' 'kanban/last-known-good'
} > "$STATE_DIR/last-known-good.env"

record_ticket_checkpoint_for_reality_check "$ticket_path"

echo "$history_tag $commit_ref"
