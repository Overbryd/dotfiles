#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "$0")" && pwd)/kanban"

usage() {
  cat <<'EOF'
Usage:
  kanban setup [project-root] [--force] [--no-plan-seed] [--plan-file <path>] [--plans-dir <path>]

Create or refresh a project-local .kanban/ skeleton.

Defaults:
  project-root  current working directory
  plan-file     PLAN.md
  plans-dir     .plans

Examples:
  kanban setup
  kanban setup ~/work/my-project
  kanban setup --force
  kanban setup --no-plan-seed
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

force=0
seed_from_plans=1
project_root_input=""
plan_file="PLAN.md"
plans_dir=".plans"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force)
      force=1
      shift
      ;;
    --no-plan-seed)
      seed_from_plans=0
      shift
      ;;
    --plan-file)
      plan_file="${2:-}"
      shift 2
      ;;
    --plans-dir)
      plans_dir="${2:-}"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      if [[ -z "$project_root_input" ]]; then
        project_root_input="$1"
        shift
      else
        echo "unknown argument: $1" >&2
        exit 1
      fi
      ;;
  esac
done

if [[ -z "$project_root_input" ]]; then
  project_root_input="$PWD"
fi

project_root="$(absolute_dir_path "$project_root_input")"
kanban_root="$project_root/.kanban"
assets_root="$KANBAN_ASSETS_DIR"

if [[ ! -d "$assets_root" ]]; then
  echo "kanban assets directory not found: $assets_root" >&2
  exit 1
fi

seed_file() {
  local source_path destination_path
  source_path="$1"
  destination_path="$2"

  mkdir -p "$(dirname "$destination_path")"

  if [[ -f "$destination_path" && "$force" -ne 1 ]]; then
    echo "kept $destination_path"
    return 0
  fi

  cp "$source_path" "$destination_path"
  echo "wrote $destination_path"
}

create_gitkeep() {
  local path
  path="$1"
  mkdir -p "$(dirname "$path")"
  : > "$path"
}

relative_to_root() {
  local path
  path="$1"

  case "$path" in
    "$project_root")
      printf '.\n'
      ;;
    "$project_root"/*)
      printf '%s\n' "${path#$project_root/}"
      ;;
    *)
      printf '%s\n' "$path"
      ;;
  esac
}

seed_plan_ticket() {
  local source_path source_rel source_title ticket_id slug ticket_path
  source_path="$1"
  source_rel="$(relative_to_root "$source_path")"
  source_title="$(kanban_markdown_title "$source_path" || true)"
  source_title="${source_title:-$(basename "$source_path") }"
  source_title="${source_title% }"
  ticket_id="$(kanban_next_ticket_id_for_dir "$kanban_root")"
  slug="$(kanban_slugify "derive work from ${source_rel}")"
  ticket_path="$kanban_root/1-to_refine/${ticket_id}-${slug}.md"

  cat > "$ticket_path" <<EOF
---
id: $ticket_id
type: planning
depends_on: []
minimum_thinking: high
---

# Derive executable kanban tickets from $source_rel

## Summary

Review \`$source_rel\` and convert its actionable work into executable .kanban tickets without copying the source plan verbatim.

## Lane Notes

- Current lane: 1-to_refine
- Order: n/a
- Owner: unassigned

## References

- \`$source_rel\`

## Acceptance Criteria

- [ ] The actionable workstreams from \`$source_rel\` are identified.
- [ ] Follow-on kanban tickets either exist already or are created with explicit scope and references back to \`$source_rel\`.
- [ ] Dependencies, blockers, and open questions are captured in the resulting tickets.

## Verification

- Inspect .kanban/ and confirm the created or updated tickets reference \`$source_rel\`.
- Confirm the queue contains executable work instead of copied plan prose.

## Notes

This ticket was generated by kanban setup from an existing planning artifact.
Original document title: $source_title
EOF

  echo "seeded $ticket_path"
}

mkdir -p \
  "$kanban_root/0-open" \
  "$kanban_root/1-to_refine" \
  "$kanban_root/2-planned" \
  "$kanban_root/3-in_progress" \
  "$kanban_root/4-in_review" \
  "$kanban_root/5-done" \
  "$kanban_root/roles" \
  "$kanban_root/templates" \
  "$kanban_root/runtime/sessions/archive" \
  "$kanban_root/runtime/state" \
  "$kanban_root/runtime/logs" \
  "$kanban_root/runtime/recovery"

for lane in 0-open 1-to_refine 2-planned 3-in_progress 4-in_review 5-done; do
  create_gitkeep "$kanban_root/$lane/.gitkeep"
done

create_gitkeep "$kanban_root/roles/.gitkeep"
create_gitkeep "$kanban_root/runtime/sessions/.gitkeep"
create_gitkeep "$kanban_root/runtime/sessions/archive/.gitkeep"
create_gitkeep "$kanban_root/runtime/state/.gitkeep"
create_gitkeep "$kanban_root/runtime/logs/.gitkeep"
create_gitkeep "$kanban_root/runtime/recovery/.gitkeep"

seed_file "$assets_root/README.md" "$kanban_root/README.md"
seed_file "$assets_root/templates/ticket.md" "$kanban_root/templates/ticket.md"
seed_file "$assets_root/runtime/.gitignore" "$kanban_root/runtime/.gitignore"

if [[ "$seed_from_plans" -eq 1 ]]; then
  if kanban_has_ticket_files "$kanban_root"; then
    echo "skipped plan seeding because ticket files already exist under $kanban_root"
  else
    seeded_plan_tickets=0

    if [[ -f "$project_root/$plan_file" ]]; then
      seed_plan_ticket "$project_root/$plan_file"
      seeded_plan_tickets=$((seeded_plan_tickets + 1))
    fi

    if [[ -d "$project_root/$plans_dir" ]]; then
      while IFS= read -r plan_source; do
        seed_plan_ticket "$plan_source"
        seeded_plan_tickets=$((seeded_plan_tickets + 1))
      done < <(find "$project_root/$plans_dir" -type f -name '*.md' | sort)
    fi

    if [[ "$seeded_plan_tickets" -eq 0 ]]; then
      echo "no existing plan artifacts found at $(relative_to_root "$project_root/$plan_file") or $(relative_to_root "$project_root/$plans_dir")"
    fi
  fi
fi

echo "ready $kanban_root"
