#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "$0")" && pwd)/kanban"

usage() {
  cat <<'EOF'
Usage:
  kanban stop-role <role>
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

role="${1:-}"
if [[ -z "$role" ]]; then
  usage
  exit 1
fi

require_project_context
require_cmd tmux

window_id="$(tmux_target_window_id)"

if ! pane_id="$(find_role_pane "$role")"; then
  echo "absent"
  exit 0
fi

tmux kill-pane -t "$pane_id"
clear_role_pane "$role"
tmux select-layout -t "$window_id" tiled >/dev/null || true

echo "stopped $pane_id"
