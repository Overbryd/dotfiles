#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "$0")" && pwd)/kanban"

usage() {
  cat <<'EOF'
Usage:
  kanban list-roles

List active kanban role panes in the project tmux window.
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

require_project_context
require_cmd tmux

window_id="$(tmux_target_window_id)"

printf '%-16s %-10s %-6s %-16s %s\n' role pane_id dead command title
while IFS=$'\t' read -r pane_id pane_title pane_dead pane_command; do
  if [[ "$pane_title" == "$PROJECT_NAME:"* ]]; then
    role="${pane_title#${PROJECT_NAME}:}"
    if [[ "$role" != "backbone" ]]; then
      printf '%-16s %-10s %-6s %-16s %s\n' "$role" "$pane_id" "$pane_dead" "$pane_command" "$pane_title"
    fi
  fi
done < <(tmux list-panes -t "$window_id" -F $'#{pane_id}\t#{pane_title}\t#{pane_dead}\t#{pane_current_command}')
