#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "$0")" && pwd)/kanban"

usage() {
  cat <<'EOF'
Usage:
  kanban start-role <role> [ticket] [--note <text>] [--provider <name>] [--thinking <level>] [--resume] [--vertical|--horizontal]

Examples:
  kanban start-role manager
  kanban start-role implementer .kanban/2-planned/03-split-config-layout.md
  kanban start-role implementer .kanban/2-planned/03-split-config-layout.md --provider openai --thinking high
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

require_project_context
require_cmd tmux pi bash
ensure_runtime_dirs

role="${1:-}"
if [[ -z "$role" ]]; then
  usage
  exit 1
fi

if [[ "$role" == "operator" ]]; then
  echo "operator is user-owned; start it with 'kanban operator' instead of 'kanban start-role operator'" >&2
  exit 1
fi

shift || true

ticket=""
note=""
provider_override=""
thinking_override=""
resume_session=0
split_flag="-h"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --note)
      note="${2:-}"
      shift 2
      ;;
    --provider)
      provider_override="${2:-}"
      shift 2
      ;;
    --thinking)
      thinking_override="${2:-}"
      shift 2
      ;;
    --resume)
      resume_session=1
      shift
      ;;
    --vertical)
      split_flag="-v"
      shift
      ;;
    --horizontal)
      split_flag="-h"
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      if [[ -z "$ticket" ]]; then
        ticket="$1"
      else
        if [[ -n "$note" ]]; then
          note+=" "
        fi
        note+="$1"
      fi
      shift
      ;;
  esac
done

if ! role_doc="$(resolve_role_doc "$role")"; then
  echo "unknown role doc for role '$role' (looked in $(builtin_role_doc_path "$role") and $(project_custom_role_doc_path "$role"))" >&2
  exit 1
fi

if [[ -n "$ticket" ]]; then
  if ! ticket="$(resolve_existing_project_file "$ticket")"; then
    echo "ticket not found: $ticket" >&2
    exit 1
  fi
fi

if pane_id="$(find_role_pane "$role" 2>/dev/null)"; then
  echo "exists $pane_id"
  exit 0
fi

window_id="$(tmux_target_window_id)"
session_file="$(session_file_for_role "$role")"
primary_provider="$(kanban_pi_primary_provider)"
fallback_provider="$(kanban_pi_fallback_provider)"
model_id="$(kanban_pi_default_model)"
provider="${provider_override:-$primary_provider}"

if [[ "$role" == "reality-check" ]]; then
  if [[ "$resume_session" -eq 1 ]]; then
    echo 'ignoring --resume for reality-check; this role always starts with a fresh session' >&2
  fi
  resume_session=0
fi

if [[ "$resume_session" -eq 0 ]]; then
  archive_session_file "$role"
fi

relative_ticket=""
if [[ -n "$ticket" ]]; then
  relative_ticket="$(relative_to_project "$ticket")"
fi

role_doc_display="$(role_doc_display_path "$role_doc")"
role_doc_arg="$(pi_file_argument "$role_doc")"
thinking_level="$(effective_role_thinking "$role" "$ticket" "$thinking_override")"

if [[ "$role" == "manager" ]]; then
  initial_message="Read .kanban/README.md and ${role_doc_display}. Also inspect .kanban/operator-blocker.md and .kanban/operator-todo.md if they exist. You are the manager inside the hard tmux backbone system. Use the kanban helper commands instead of raw tmux whenever possible, especially kanban list-roles, kanban capture-role, kanban start-role, kanban stop-role, kanban send-role, and kanban checkpoint-ticket. Reconcile .kanban lanes, worker panes, and git state. You are ultimately responsible for adjusting priorities and keeping work moving from 0-open to 1-to_refine to 2-planned to 3-in_progress to 4-in_review to 5-done. Priority order is: immediate tickets first, then reality-check cleanup stream, then normal work. Tickets with priority: ignore are not actionable, and tickets in 0-open without a priority are also ignored. If a reality-check findings ticket exists, prioritize it and the cleanup subtickets derived from it ahead of unrelated normal work, but never ahead of immediate tickets. Keep the operator blocker and operator todo files clean whenever the system needs operator answers or operator review. If nothing higher-priority is active, start a real refinement pass on the best actionable ticket in 1-to_refine instead of idling. Delegate work by starting role panes inside this same tmux window. There must be at most one pane per role. Files and git state are authoritative over memory. Ensure a reality-check role is launched at least once every two hours or after three checkpointed tickets, especially when the backbone healthcheck says it is due. When the backbone asks for a periodic healthcheck, do one bounded reconciliation pass, report the result, and if that pass reveals a single clear follow-on task launch it before stopping. Only wait when there is no clear immediate next action. Begin now."
elif [[ "$role" == "reality-check" ]]; then
  initial_message="Read .kanban/README.md and ${role_doc_display}. This role always starts with a fresh session and must not rely on prior conversation state. Rebuild fresh context from the broader project before making any recommendation. Audit for drift, half-implemented work, over-mocking, stubbed behavior, weak integration seams, bad code style, and shortcuts that keep the system from becoming real and production-ready. Write or update exactly one findings ticket as directed by the role file, then stop."
else
  initial_message="Read .kanban/README.md and ${role_doc_display}."

  if [[ -n "$relative_ticket" ]]; then
    initial_message+=" Also read ${relative_ticket} and work only within that ticket's scope."
  fi

  initial_message+=" You were started by the manager inside the hard tmux backbone system. Do not rename panes or spawn sibling panes unless your role explicitly requires it. Files and git state are authoritative over memory. Update the ticket before idling or stopping."
fi

if [[ -n "$note" ]]; then
  initial_message+=" ${note}"
fi

launch_script="$STATE_DIR/start-${role}-$(date -u +"%Y%m%dT%H%M%SZ").sh"
pane_title="$(role_title "$role")"
args=(--provider "$provider" --model "$model_id" --thinking "$thinking_level" --session "$session_file" "@.kanban/README.md" "$role_doc_arg")

if [[ -n "$relative_ticket" ]]; then
  args+=("@${relative_ticket}")
fi

args+=("$initial_message")

{
  printf '#!/usr/bin/env bash\n'
  printf 'set -euo pipefail\n'
  printf 'cd %q\n' "$PROJECT_ROOT"
  printf 'role_name=%q\n' "$role"
  printf 'pane_title=%q\n' "$pane_title"
  printf 'provider=%q\n' "$provider"
  printf 'model_id=%q\n' "$model_id"
  printf 'thinking_level=%q\n' "$thinking_level"
  printf 'fallback_provider=%q\n' "$fallback_provider"
  printf 'if [[ -n "${TMUX_PANE:-}" ]]; then\n'
  printf '  tmux set-window-option -t "$TMUX_PANE" allow-set-title off >/dev/null 2>&1 || true\n'
  printf '  tmux select-pane -t "$TMUX_PANE" -T "$pane_title" >/dev/null 2>&1 || true\n'
  printf 'fi\n'
  printf 'printf "[kanban] role=%s provider=%s model=%s thinking=%s fallback_provider=%s\\n" "$role_name" "$provider" "$model_id" "$thinking_level" "$fallback_provider"\n'
  printf 'exec pi'
  for arg in "${args[@]}"; do
    printf ' %q' "$arg"
  done
  printf '\n'
} > "$launch_script"

command_string="bash $(printf '%q' "$launch_script")"
pane_id="$(tmux split-window "$split_flag" -P -F '#{pane_id}' -t "$window_id" -c "$PROJECT_ROOT" "$command_string")"
lock_pane_title_from_app_changes "$pane_id"
set_pane_title "$pane_id" "$pane_title"
record_role_pane "$role" "$pane_id"

if [[ "$role" == "reality-check" ]]; then
  record_reality_check_launch start-role
fi

ensure_single_role_pane "$role" >/dev/null

tmux select-layout -t "$window_id" tiled >/dev/null || true

echo "created $pane_id"
