#!/usr/bin/python3

"""wsync: plan-first workspace sync tool.

Current status:
- Python CLI for pull/push/doctor
- path/profile target resolution
- Git root detection
- mixed-tree planning with nested Git repos excluded from plain-dir chunks
- plan file generation in ~/.local/state/wsync/runs/<run-id>/plan.txt
- doctor command for local/remote prerequisites
- portable rsync dry-run previews for plain-dir and repo-overlay chunks
- confirm-to-apply flow with editable plan
- vendored tomli fallback for Python 3.9
"""

import fnmatch
import json
import os
import shlex
import shutil
import socket
import subprocess
import sys
from dataclasses import dataclass, field
from datetime import datetime
from pathlib import Path
from typing import Any, Dict, List, Optional, Sequence, Set, Tuple


DEFAULT_RSYNC_CANDIDATES = [
    "/opt/homebrew/bin/rsync",
    "/usr/local/bin/rsync",
    "/usr/bin/rsync",
]

DEFAULT_COMMON_EXCLUDES = [
    ".DS_Store",
    ".direnv/",
    ".terraform/",
    "__pycache__/",
    ".cache/",
]

MAX_SCAN_DIRS = 10_000
MAX_PREVIEW_LINES = 40

REMOTE_OVERLAY_LIST_SCRIPT = r'''
import fnmatch
import json
import os
import subprocess
import sys

repo = os.path.realpath(sys.argv[1])
includes = json.loads(sys.argv[2])


def run(args):
    return subprocess.run(args, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)


def tracked_paths(repo_root):
    result = run(["git", "-C", repo_root, "ls-files", "-z"])
    if result.returncode != 0:
        raise SystemExit(result.stderr.strip() or "git ls-files failed")
    return {path for path in result.stdout.split("\0") if path}


def untracked_paths(repo_root):
    result = run(["git", "-C", repo_root, "ls-files", "--others", "--exclude-standard", "-z"])
    if result.returncode != 0:
        raise SystemExit(result.stderr.strip() or "git ls-files --others failed")
    return {path for path in result.stdout.split("\0") if path}


def collect_subtree(repo_root, rel_path):
    target = os.path.join(repo_root, rel_path)
    if not (os.path.exists(target) or os.path.islink(target)):
        return set()
    results = set()
    if os.path.islink(target) or os.path.isfile(target):
        results.add(rel_path)
        return results
    for current_root, dirnames, filenames in os.walk(target, topdown=True, followlinks=False):
        rel_root = os.path.relpath(current_root, repo_root)
        if rel_root == '.':
            rel_root = ''
        keep = []
        for dirname in dirnames:
            candidate = os.path.join(current_root, dirname)
            rel = os.path.join(rel_root, dirname) if rel_root else dirname
            rel = rel.replace(os.sep, '/')
            if os.path.islink(candidate):
                results.add(rel)
            else:
                keep.append(dirname)
        dirnames[:] = keep
        for filename in filenames:
            rel = os.path.join(rel_root, filename) if rel_root else filename
            results.add(rel.replace(os.sep, '/'))
    return results


def collect_matches(repo_root, pattern):
    pattern = pattern.replace('\\', '/')
    if pattern.endswith('/***'):
        base = pattern[:-4].rstrip('/')
        return collect_subtree(repo_root, base)
    if not any(ch in pattern for ch in '*?[]'):
        return collect_subtree(repo_root, pattern)
    results = set()
    for current_root, dirnames, filenames in os.walk(repo_root, topdown=True, followlinks=False):
        rel_root = os.path.relpath(current_root, repo_root)
        if rel_root == '.':
            rel_root = ''
        keep = []
        for dirname in dirnames:
            candidate = os.path.join(current_root, dirname)
            rel = os.path.join(rel_root, dirname) if rel_root else dirname
            rel = rel.replace(os.sep, '/')
            if os.path.islink(candidate):
                if fnmatch.fnmatch(rel, pattern):
                    results.add(rel)
            else:
                keep.append(dirname)
        dirnames[:] = keep
        for filename in filenames:
            rel = os.path.join(rel_root, filename) if rel_root else filename
            rel = rel.replace(os.sep, '/')
            if fnmatch.fnmatch(rel, pattern):
                results.add(rel)
    return results


tracked = tracked_paths(repo)
results = set(untracked_paths(repo))
for pattern in includes:
    results.update(path for path in collect_matches(repo, pattern) if path not in tracked and not path.startswith('.git/'))
for path in sorted(path for path in results if path and path not in tracked and not path.startswith('.git/')):
    print(path)
'''


class UserError(Exception):
    pass


@dataclass
class Command:
    action: str
    target: Optional[str] = None


@dataclass
class RootSpec:
    path: Path
    source: str
    includes: List[str] = field(default_factory=list)
    excludes: List[str] = field(default_factory=list)
    presets: List[str] = field(default_factory=list)


@dataclass
class Target:
    kind: str
    label: str
    roots: List[RootSpec]


@dataclass
class GitSnapshot:
    repo_path: Path
    branch: str
    head: str
    upstream: Optional[str]
    ahead: Optional[int]
    behind: Optional[int]
    tracked_dirty: int
    untracked: int
    detached: bool
    available: bool = True
    error: Optional[str] = None


@dataclass
class PlanChunk:
    chunk_type: str
    path: Path
    direction: str
    summary: str
    lines: List[str] = field(default_factory=list)
    applyable: bool = False
    status: str = "planned"
    chunk_id: str = ""
    metadata: Dict[str, Any] = field(default_factory=dict, repr=False)

    def render(self) -> str:
        applyable_value = "yes" if self.applyable else "no"
        body = [
            "=== {} ===".format(self.chunk_id),
            "type = {}".format(self.chunk_type),
            "path = {}".format(self.path),
            "direction = {}".format(self.direction),
            "status = {}".format(self.status),
            "applyable = {}".format(applyable_value),
            "summary = {}".format(self.summary),
        ]
        if self.lines:
            body.append("")
            body.extend(self.lines)
        return "\n".join(body)


@dataclass
class Plan:
    run_id: str
    action: str
    target_label: str
    plan_path: Path
    chunks: List[PlanChunk] = field(default_factory=list)

    def render(self) -> str:
        header = [
            "# wsync plan",
            "run_id = {}".format(self.run_id),
            "action = {}".format(self.action),
            "target = {}".format(self.target_label),
            "generated_at = {}".format(datetime.now().isoformat(timespec="seconds")),
            "chunk_count = {}".format(len(self.chunks)),
            "confirm_to_apply = true",
        ]
        chunks_text = "\n\n\n".join(chunk.render() for chunk in self.chunks)
        if not chunks_text:
            chunks_text = "# no chunks generated"
        return "\n".join(header) + "\n\n\n" + chunks_text + "\n"


