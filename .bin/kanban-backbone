#!/usr/bin/env bash
set -euo pipefail

source "$(cd -- "$(dirname -- "$0")" && pwd)/kanban"

usage() {
  cat <<'EOF'
Usage:
  kanban backbone [--once]

Run the tmux supervisor loop in the current tmux pane.
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

require_project_context
require_cmd tmux pi git bash
ensure_runtime_dirs

if [[ -z "${TMUX:-}" ]]; then
  echo 'kanban backbone must be started from inside tmux' >&2
  exit 1
fi

once=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --once)
      once=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

START_ROLE_CMD="$(kanban_subcommand_path start-role)"
SEND_ROLE_CMD="$(kanban_subcommand_path send-role)"
HARD_RESET_CMD="$(kanban_subcommand_path hard-reset)"
RECOVER_CMD="$(kanban_subcommand_path recover)"
HEALTHCHECK_MANAGER_CMD="$(kanban_subcommand_path healthcheck-manager)"

sleep_seconds="${PI_BACKBONE_SLEEP_SECONDS:-10}"
stale_nudge_cooldown_seconds="${PI_BACKBONE_STALE_NUDGE_COOLDOWN_SECONDS:-120}"
nudge_cooldown_seconds="${PI_BACKBONE_NUDGE_COOLDOWN_SECONDS:-1800}"
manager_compact_idle_count="${PI_BACKBONE_MANAGER_COMPACT_IDLE_COUNT:-8}"
manager_compact_cooldown_seconds="${PI_BACKBONE_MANAGER_COMPACT_COOLDOWN_SECONDS:-1800}"
send_role_timeout_seconds="${PI_KANBAN_SEND_ROLE_TIMEOUT_SECONDS:-10}"
max_runtime_seconds="${PI_BACKBONE_MAX_RUNTIME_SECONDS:-28800}"
stale_pane_lines="$(window_role_stale_lines)"
stale_pane_threshold_checks="$(window_role_stale_threshold_checks)"
base_healthcheck_prompt='Periodic healthcheck: do one bounded reconciliation pass per your manager instructions. Re-read the current .kanban lanes, inspect active roles with the kanban helper commands, inspect .kanban/operator-blocker.md and .kanban/operator-todo.md if they exist, report the result in the pane output, and launch at most one clear follow-on task before waiting.'
export KANBAN_LOG_FILE="$LOG_DIR/backbone.log"

rotate_log_file "$KANBAN_LOG_FILE"
reset_manager_health_state
reset_window_role_activity_state
ensure_reality_check_state

session_id="$(tmux display-message -p '#{session_id}')"
window_id="$(tmux display-message -p '#{window_id}')"
backbone_pane_id="$(tmux display-message -p '#{pane_id}')"
started_at="$(date +%s)"
deadline_at=$(( started_at + max_runtime_seconds ))

write_backbone_env "$session_id" "$window_id" "$backbone_pane_id"
set_window_visuals "$window_id"
ensure_single_backbone_pane "$backbone_pane_id"
write_backbone_env "$session_id" "$window_id" "$backbone_pane_id"
log "backbone start: pid=$$ session=$session_id window=$window_id pane=$backbone_pane_id sleep_seconds=$sleep_seconds stale_nudge_cooldown_seconds=$stale_nudge_cooldown_seconds nudge_cooldown_seconds=$nudge_cooldown_seconds stale_pane_lines=$stale_pane_lines stale_pane_threshold_checks=$stale_pane_threshold_checks manager_compact_idle_count=$manager_compact_idle_count manager_compact_cooldown_seconds=$manager_compact_cooldown_seconds send_role_timeout_seconds=$send_role_timeout_seconds max_runtime_seconds=$max_runtime_seconds deadline_at=$deadline_at"

start_manager() {
  "$START_ROLE_CMD" manager >/dev/null
}

backbone_status_state_file() {
  printf '%s/backbone-status.env\n' "$STATE_DIR"
}

reset_backbone_status_state() {
  rm -f "$(backbone_status_state_file)"
}

status_log() {
  local key message repeat_seconds state_file now last_key last_logged_at
  key="$1"
  message="$2"
  repeat_seconds="${3:-300}"
  state_file="$(backbone_status_state_file)"
  now="$(date +%s)"
  last_key=""
  last_logged_at="0"

  if [[ -f "$state_file" ]]; then
    # shellcheck disable=SC1090
    source "$state_file"
  fi

  if [[ "$key" == "${last_key:-}" ]] && (( now - ${last_logged_at:-0} < repeat_seconds )); then
    return 0
  fi

  {
    printf 'last_key=%q\n' "$key"
    printf 'last_logged_at=%q\n' "$now"
  } > "$state_file"

  log "$message"
}

reset_backbone_status_state

manager_healthcheck_prompt() {
  local prompt immediate_guidance reality_check_guidance
  prompt="$base_healthcheck_prompt"
  immediate_guidance="$(immediate_ticket_healthcheck_guidance || true)"
  reality_check_guidance="$(reality_check_healthcheck_guidance || true)"

  if [[ -n "$immediate_guidance" ]]; then
    prompt+=" ${immediate_guidance}"
  fi

  if [[ -n "$reality_check_guidance" ]]; then
    prompt+=" ${reality_check_guidance}"
  fi

  printf '%s\n' "$prompt"
}

send_manager_healthcheck_prompt() {
  local reason prompt
  reason="$1"
  prompt="$(manager_healthcheck_prompt)"

  if run_with_timeout "$send_role_timeout_seconds" "$SEND_ROLE_CMD" manager "$prompt" >/dev/null 2>&1; then
    record_manager_nudge "$reason"
    return 0
  fi

  return 1
}

maybe_nudge_manager_early_on_all_idle() {
  local seconds_remaining

  if ! window_role_panes_all_idle; then
    set_window_role_idle_latch 0
    return 1
  fi

  if window_role_idle_latched; then
    status_log 'all-managed-panes-stale-latched' 'manager healthcheck: idle; all managed panes appear stale; deferring repeat early nudge until pane output changes' 300
    return 1
  fi

  if ! manager_nudge_due "$stale_nudge_cooldown_seconds"; then
    seconds_remaining="$(seconds_until_manager_nudge "$stale_nudge_cooldown_seconds")"
    status_log 'all-managed-panes-stale-cooldown' "manager healthcheck: idle; all managed panes appear stale; early nudge cooldown active (${seconds_remaining}s remaining)" 120
    return 1
  fi

  if send_manager_healthcheck_prompt all-managed-panes-stale; then
    set_window_role_idle_latch 1
    log 'manager healthcheck: idle; all managed panes appear stale; nudged manager early'
    return 0
  fi

  log 'manager healthcheck: idle; all managed panes appear stale; early nudge failed because manager pane was unavailable'
  return 1
}

nudge_manager() {
  local idle_count seconds_remaining compact_seconds_remaining
  idle_count="$1"

  if ! manager_nudge_due "$nudge_cooldown_seconds"; then
    seconds_remaining="$(seconds_until_manager_nudge "$nudge_cooldown_seconds")"
    status_log 'idle-periodic-cooldown' "manager healthcheck: idle (count=$idle_count); periodic nudge deferred (${seconds_remaining}s remaining)" 300
    return 1
  fi

  if (( idle_count >= manager_compact_idle_count )); then
    if manager_compact_due "$manager_compact_cooldown_seconds"; then
      run_with_timeout "$send_role_timeout_seconds" "$SEND_ROLE_CMD" manager '/compact' >/dev/null 2>&1 || true
      record_manager_compact
      log "manager healthcheck: idle (count=$idle_count); sent /compact before periodic healthcheck"
      sleep 2
    else
      compact_seconds_remaining="$(seconds_until_manager_compact "$manager_compact_cooldown_seconds")"
      status_log 'idle-compact-cooldown' "manager healthcheck: idle (count=$idle_count); skipped /compact (${compact_seconds_remaining}s compact cooldown remaining)" 300
    fi
  fi

  if send_manager_healthcheck_prompt periodic-healthcheck; then
    log "manager healthcheck: idle (count=$idle_count); nudged manager"
    return 0
  fi

  log "manager healthcheck: idle (count=$idle_count); nudge failed because manager pane was unavailable"
  return 1
}

recover_and_restart() {
  log 'hard reset: stopping all role panes'
  "$HARD_RESET_CMD" >/dev/null 2>&1 || true

  log 'hard reset: running recovery'
  if ! "$RECOVER_CMD" >/dev/null 2>&1; then
    log 'recovery failed; continuing to manager restart anyway'
  fi

  log 'hard reset: restarting manager'
  start_manager
}

empty_queue_watch_snapshot() {
  local file effective_priority

  while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    effective_priority="$(ticket_effective_priority_from_file "$file")"

    if [[ "$effective_priority" == "ignore" ]]; then
      continue
    fi

    printf '%s\t%s\n' "$effective_priority" "$(relative_to_project "$file")"
  done < <(kanban_active_lane_ticket_files "$KANBAN_DIR")
}

empty_queue_watch_applicable() {
  local processable_count worker_role_count
  processable_count="$(kanban_processable_ticket_files "$KANBAN_DIR" | wc -l | tr -d ' ')"
  worker_role_count="$(window_worker_role_count)"

  [[ "$processable_count" == "0" && "$worker_role_count" == "0" ]]
}

maybe_wake_manager_for_due_reality_check() {
  local due_reason seconds_remaining
  due_reason="$(reality_check_due_reason)"

  if [[ "$due_reason" == "none" ]]; then
    return 1
  fi

  if ! manager_nudge_due "$nudge_cooldown_seconds"; then
    seconds_remaining="$(seconds_until_manager_nudge "$nudge_cooldown_seconds")"
    status_log 'reality-check-periodic-cooldown' "manager healthcheck: idle; reality-check is due ($due_reason) but periodic nudge is deferred (${seconds_remaining}s remaining)" 300
    return 1
  fi

  if send_manager_healthcheck_prompt "reality-check-$due_reason"; then
    log "manager healthcheck: idle; reality-check due ($due_reason); nudged manager"
    return 0
  fi

  log "manager healthcheck: idle; reality-check due ($due_reason); wake-up failed because manager pane was unavailable"
  return 1
}

handle_empty_queue_idle() {
  local current_snapshot due_reason

  if ! empty_queue_watch_applicable; then
    empty_queue_watch_mode=0
    empty_queue_watch_snapshot_cache=""
    return 1
  fi

  current_snapshot="$(empty_queue_watch_snapshot)"
  due_reason="$(reality_check_due_reason)"

  if [[ "$empty_queue_watch_mode" -eq 0 ]]; then
    empty_queue_watch_mode=1
    empty_queue_watch_snapshot_cache="$current_snapshot"
    log 'manager healthcheck: idle; empty ready queue detected; entering file-watch idle mode'

    if [[ "$due_reason" != "none" ]]; then
      maybe_wake_manager_for_due_reality_check || true
    fi

    return 0
  fi

  if [[ "$current_snapshot" == "$empty_queue_watch_snapshot_cache" ]]; then
    if [[ "$due_reason" != "none" ]]; then
      maybe_wake_manager_for_due_reality_check || true
    fi
    return 0
  fi

  empty_queue_watch_mode=0
  empty_queue_watch_snapshot_cache=""
  set_window_role_idle_latch 0
  log 'manager healthcheck: idle; kanban lane files changed while empty queue watch was active; waking manager'

  if send_manager_healthcheck_prompt kanban-lane-change; then
    return 0
  fi

  log 'manager healthcheck: idle; lane change wake-up failed because manager pane was unavailable'
  return 0
}

idle_count=0
empty_queue_watch_mode=0
empty_queue_watch_snapshot_cache=""
start_manager

while true; do
  now="$(date +%s)"
  if (( now >= deadline_at )); then
    log 'backbone max runtime reached; exiting supervisor loop'
    exit 0
  fi

  result="$($HEALTHCHECK_MANAGER_CMD 2>/dev/null || echo stuck)"

  case "$result" in
    working)
      idle_count=0
      empty_queue_watch_mode=0
      empty_queue_watch_snapshot_cache=""
      set_window_role_idle_latch 0
      window_role_panes_all_idle >/dev/null 2>&1 || true
      status_log 'manager-working' 'manager healthcheck: working' 300
      ;;
    missing)
      idle_count=0
      empty_queue_watch_mode=0
      empty_queue_watch_snapshot_cache=""
      set_window_role_idle_latch 0
      reset_window_role_activity_state
      log 'manager healthcheck: missing; starting manager'
      start_manager
      ;;
    idle)
      if handle_empty_queue_idle; then
        idle_count=0
      else
        idle_count=$((idle_count + 1))
        if maybe_nudge_manager_early_on_all_idle; then
          idle_count=0
        else
          nudge_manager "$idle_count" || true
        fi
      fi
      ;;
    suspect)
      idle_count=0
      empty_queue_watch_mode=0
      empty_queue_watch_snapshot_cache=""
      set_window_role_idle_latch 0
      if [[ -f "$STATE_DIR/manager-health.env" ]]; then
        # shellcheck disable=SC1090
        source "$STATE_DIR/manager-health.env"
      fi
      status_log "manager-suspect-${suspicion_reason:-unknown}" "manager healthcheck: suspect; reason=${suspicion_reason:-unknown} elapsed=${suspicion_elapsed_seconds:-0}s" 300
      ;;
    stuck|restart)
      idle_count=0
      empty_queue_watch_mode=0
      empty_queue_watch_snapshot_cache=""
      set_window_role_idle_latch 0
      reset_window_role_activity_state
      log "manager healthcheck: $result; performing hard reset"
      recover_and_restart
      ;;
    *)
      idle_count=0
      empty_queue_watch_mode=0
      empty_queue_watch_snapshot_cache=""
      set_window_role_idle_latch 0
      reset_window_role_activity_state
      log "manager healthcheck: unknown result '$result'; performing hard reset"
      recover_and_restart
      ;;
  esac

  if [[ "$once" -eq 1 ]]; then
    exit 0
  fi

  now="$(date +%s)"
  remaining_seconds=$(( deadline_at - now ))
  if (( remaining_seconds <= 0 )); then
    log 'backbone max runtime reached; exiting supervisor loop'
    exit 0
  fi

  if (( remaining_seconds < sleep_seconds )); then
    sleep "$remaining_seconds"
  else
    sleep "$sleep_seconds"
  fi
done
