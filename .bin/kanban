#!/usr/bin/env bash
set -euo pipefail

KANBAN_BIN_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
KANBAN_INSTALL_ROOT="$(cd -- "$KANBAN_BIN_DIR/.." && pwd)"
KANBAN_ASSETS_DIR="$KANBAN_INSTALL_ROOT/pi/kanban"
KANBAN_PROJECT_CONTEXT_LOADED=0

kanban_usage() {
  local subcommands=""

  if subcommands="$(kanban_available_subcommands 2>/dev/null)"; then
    :
  else
    subcommands=""
  fi

  cat <<EOF
Usage:
  kanban <subcommand> [args]
  kanban help [subcommand]

Project commands operate on the nearest parent .kanban/ directory.
Run inside a project created with 'kanban setup'.

Available subcommands:
${subcommands:-  setup
  backbone
  start-role
  stop-role
  list-roles
  capture-role
  send-role
  healthcheck-manager
  hard-reset
  recover
  checkpoint-ticket}
EOF
}

die() {
  echo "$*" >&2
  exit 1
}

absolute_existing_path() {
  local path
  path="$1"

  if [[ -d "$path" ]]; then
    (
      cd -- "$path"
      pwd -P
    )
    return 0
  fi

  (
    cd -- "$(dirname -- "$path")"
    printf '%s/%s\n' "$(pwd -P)" "$(basename -- "$path")"
  )
}

absolute_dir_path() {
  local path
  path="$1"

  mkdir -p "$path"
  (
    cd -- "$path"
    pwd -P
  )
}

discover_kanban_dir() {
  local start_dir dir candidate

  if [[ -n "${KANBAN_DIR:-}" && -d "${KANBAN_DIR:-}" ]]; then
    absolute_existing_path "$KANBAN_DIR"
    return 0
  fi

  if [[ -n "${KANBAN_PROJECT_ROOT:-}" && -d "${KANBAN_PROJECT_ROOT:-}/.kanban" ]]; then
    absolute_existing_path "${KANBAN_PROJECT_ROOT}/.kanban"
    return 0
  fi

  start_dir="${1:-$PWD}"
  dir="$(cd -- "$start_dir" && pwd -P)"

  while true; do
    if [[ "$(basename -- "$dir")" == ".kanban" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi

    candidate="$dir/.kanban"
    if [[ -d "$candidate" ]]; then
      absolute_existing_path "$candidate"
      return 0
    fi

    if [[ "$dir" == "/" ]]; then
      break
    fi

    dir="$(dirname -- "$dir")"
  done

  return 1
}

load_project_context() {
  local kanban_dir

  if [[ "$KANBAN_PROJECT_CONTEXT_LOADED" == "1" ]]; then
    return 0
  fi

  kanban_dir="$(discover_kanban_dir "${1:-$PWD}")" || return 1

  KANBAN_DIR="$kanban_dir"
  PROJECT_ROOT="$(cd -- "$KANBAN_DIR/.." && pwd -P)"
  PROJECT_NAME="$(basename "$PROJECT_ROOT")"
  RUNTIME_DIR="$KANBAN_DIR/runtime"
  SESSIONS_DIR="$RUNTIME_DIR/sessions"
  ARCHIVE_DIR="$SESSIONS_DIR/archive"
  STATE_DIR="$RUNTIME_DIR/state"
  LOG_DIR="$RUNTIME_DIR/logs"
  RECOVERY_DIR="$RUNTIME_DIR/recovery"
  BACKBONE_ENV_FILE="$RUNTIME_DIR/backbone.env"
  KANBAN_PROJECT_CONTEXT_LOADED=1
}

require_project_context() {
  if load_project_context "${1:-$PWD}"; then
    return 0
  fi

  die "could not find .kanban/ from $PWD; run 'kanban setup' in your project first"
}

resolve_existing_project_file() {
  local input candidate
  input="$1"

  require_project_context

  if [[ "$input" == /* ]]; then
    candidate="$input"
  elif [[ -e "$input" ]]; then
    candidate="$input"
  else
    candidate="$PROJECT_ROOT/$input"
  fi

  if [[ ! -e "$candidate" ]]; then
    return 1
  fi

  absolute_existing_path "$candidate"
}

kanban_subcommand_path() {
  local subcommand candidate
  subcommand="$1"

  case "$subcommand" in
    ""|*/*)
      return 1
      ;;
  esac

  candidate="$KANBAN_BIN_DIR/kanban-$subcommand"
  if [[ -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  candidate="$(command -v "kanban-$subcommand" 2>/dev/null || true)"
  if [[ -n "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

kanban_available_subcommands() {
  local path

  for path in "$KANBAN_BIN_DIR"/kanban-*; do
    [[ -e "$path" ]] || continue
    [[ -x "$path" ]] || continue
    printf '  %s\n' "${path##*/kanban-}"
  done | sort -u
}

ensure_runtime_dirs() {
  mkdir -p "$SESSIONS_DIR" "$ARCHIVE_DIR" "$STATE_DIR" "$LOG_DIR" "$RECOVERY_DIR"
}

log() {
  local ts message
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  message="[$ts] $*"
  echo "$message" >&2

  if [[ -n "${KANBAN_LOG_FILE:-}" ]]; then
    mkdir -p "$(dirname "$KANBAN_LOG_FILE")"
    echo "$message" >> "$KANBAN_LOG_FILE"
  fi
}

rotate_log_file() {
  local log_file rotated_file
  log_file="$1"

  if [[ -f "$log_file" && -s "$log_file" ]]; then
    rotated_file="${log_file%.log}-$(date -u +"%Y%m%dT%H%M%SZ").log"
    mv "$log_file" "$rotated_file"
  fi
}

require_cmd() {
  local command

  for command in "$@"; do
    if ! command -v "$command" >/dev/null 2>&1; then
      echo "missing required command: $command" >&2
      exit 1
    fi
  done
}

source_backbone_env() {
  if [[ -f "$BACKBONE_ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$BACKBONE_ENV_FILE"
  fi
}

tmux_target_window_id() {
  source_backbone_env

  if [[ -n "${KANBAN_TMUX_WINDOW_ID:-}" ]]; then
    printf '%s\n' "$KANBAN_TMUX_WINDOW_ID"
    return 0
  fi

  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{window_id}'
    return 0
  fi

  return 1
}

tmux_target_session_id() {
  source_backbone_env

  if [[ -n "${KANBAN_TMUX_SESSION_ID:-}" ]]; then
    printf '%s\n' "$KANBAN_TMUX_SESSION_ID"
    return 0
  fi

  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{session_id}'
    return 0
  fi

  return 1
}

write_backbone_env() {
  local session_id window_id backbone_pane_id
  session_id="$1"
  window_id="$2"
  backbone_pane_id="$3"

  ensure_runtime_dirs

  {
    printf 'KANBAN_PROJECT_ROOT=%q\n' "$PROJECT_ROOT"
    printf 'KANBAN_PROJECT_NAME=%q\n' "$PROJECT_NAME"
    printf 'KANBAN_KANBAN_DIR=%q\n' "$KANBAN_DIR"
    printf 'KANBAN_RUNTIME_DIR=%q\n' "$RUNTIME_DIR"
    printf 'KANBAN_TMUX_SESSION_ID=%q\n' "$session_id"
    printf 'KANBAN_TMUX_WINDOW_ID=%q\n' "$window_id"
    printf 'KANBAN_TMUX_BACKBONE_PANE_ID=%q\n' "$backbone_pane_id"
  } > "$BACKBONE_ENV_FILE"
}

set_window_visuals() {
  local window_id
  window_id="$1"

  tmux rename-window -t "$window_id" "$PROJECT_NAME"
  tmux set-window-option -t "$window_id" pane-border-status top >/dev/null
  tmux set-window-option -t "$window_id" pane-border-format '#{pane_title}' >/dev/null
}

set_pane_title() {
  local pane_id title
  pane_id="$1"
  title="$2"
  tmux select-pane -t "$pane_id" -T "$title"
}

role_title() {
  printf '%s:%s\n' "$PROJECT_NAME" "$1"
}

backbone_title() {
  role_title backbone
}

is_backbone_title() {
  [[ "$1" == "$(backbone_title)" ]]
}

relative_to_project() {
  local path
  path="$1"

  case "$path" in
    "$PROJECT_ROOT")
      printf '.\n'
      ;;
    "$PROJECT_ROOT"/*)
      printf '%s\n' "${path#$PROJECT_ROOT/}"
      ;;
    *)
      printf '%s\n' "$path"
      ;;
  esac
}

session_file_for_role() {
  printf '%s/%s.jsonl\n' "$SESSIONS_DIR" "$1"
}

archive_session_file() {
  local role session_file archived_file
  role="$1"
  session_file="$(session_file_for_role "$role")"

  if [[ -f "$session_file" ]]; then
    archived_file="$ARCHIVE_DIR/${role}-$(date -u +"%Y%m%dT%H%M%SZ").jsonl"
    mv "$session_file" "$archived_file"
  fi
}

role_state_file() {
  printf '%s/role-%s.env\n' "$STATE_DIR" "$1"
}

pane_exists() {
  tmux display-message -p -t "$1" '#{pane_id}' >/dev/null 2>&1
}

record_role_pane() {
  local role pane_id state_file
  role="$1"
  pane_id="$2"
  state_file="$(role_state_file "$role")"

  {
    printf 'role=%q\n' "$role"
    printf 'pane_id=%q\n' "$pane_id"
  } > "$state_file"
}

clear_role_pane() {
  rm -f "$(role_state_file "$1")"
}

stored_role_pane() {
  local role state_file pane_id window_id pane_window_id
  role="$1"
  state_file="$(role_state_file "$role")"
  window_id="$(tmux_target_window_id)"

  if [[ ! -f "$state_file" ]]; then
    return 1
  fi

  # shellcheck disable=SC1090
  source "$state_file"

  if [[ -z "${pane_id:-}" ]]; then
    return 1
  fi

  if ! pane_exists "$pane_id"; then
    return 1
  fi

  pane_window_id="$(tmux display-message -p -t "$pane_id" '#{window_id}')"
  if [[ "$pane_window_id" != "$window_id" ]]; then
    return 1
  fi

  printf '%s\n' "$pane_id"
}

find_role_panes() {
  local role title window_id pane_id pane_title candidate declared=()
  role="$1"
  title="$(role_title "$role")"
  window_id="$(tmux_target_window_id)"

  if candidate="$(stored_role_pane "$role" 2>/dev/null)"; then
    declared+=("$candidate")
  fi

  while IFS=$'\t' read -r pane_id pane_title; do
    if [[ "$pane_title" == "$title" ]]; then
      declared+=("$pane_id")
    fi
  done < <(tmux list-panes -t "$window_id" -F $'#{pane_id}\t#{pane_title}')

  if [[ ${#declared[@]} -eq 0 ]]; then
    return 1
  fi

  printf '%s\n' "${declared[@]}" | awk '!seen[$0]++'
}

ensure_single_role_pane() {
  local role primary pane_id title
  role="$1"
  title="$(role_title "$role")"
  primary=""

  if pane_id="$(stored_role_pane "$role" 2>/dev/null)"; then
    primary="$pane_id"
  fi

  while IFS= read -r pane_id; do
    [[ -z "$pane_id" ]] && continue

    if [[ -z "$primary" ]]; then
      primary="$pane_id"
      continue
    fi

    if [[ "$pane_id" != "$primary" ]] && pane_exists "$pane_id"; then
      tmux kill-pane -t "$pane_id"
    fi
  done < <(find_role_panes "$role" 2>/dev/null || true)

  if [[ -n "$primary" ]] && pane_exists "$primary"; then
    set_pane_title "$primary" "$title"
    record_role_pane "$role" "$primary"
    printf '%s\n' "$primary"
    return 0
  fi

  clear_role_pane "$role"
  return 1
}

find_role_pane() {
  ensure_single_role_pane "$1"
}

strip_ansi() {
  perl -pe 's/\e\[[0-9;?]*[ -\/]*[@-~]//g; s/\e\][^\a]*(?:\a|\e\\)//g; s/\r//g'
}

capture_pane_lines() {
  local pane_id lines
  pane_id="$1"
  lines="$2"

  tmux capture-pane -pJ -t "$pane_id" -S "-$lines" | strip_ansi
}

normalize_pane_snapshot() {
  local drop_last_lines
  drop_last_lines="${1:-4}"

  awk -v drop_last_lines="$drop_last_lines" '
    {
      sub(/[[:space:]]+$/, "")
      lines[++count] = $0
    }
    END {
      limit = count - drop_last_lines
      if (limit < 1) {
        limit = count
      }

      for (i = 1; i <= limit; i++) {
        print lines[i]
      }
    }
  '
}

ticket_id_from_file() {
  awk '/^id:/ { print $2; exit }' "$1"
}

ticket_minimum_thinking_from_file() {
  awk '/^minimum_thinking:/ { print $2; exit }' "$1"
}

ticket_title_from_file() {
  sed -n 's/^# //p' "$1" | head -n 1
}

valid_thinking_level() {
  case "$1" in
    off|minimal|low|medium|high|xhigh)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

thinking_level_rank() {
  case "$1" in
    off) printf '0\n' ;;
    minimal) printf '1\n' ;;
    low) printf '2\n' ;;
    medium) printf '3\n' ;;
    high) printf '4\n' ;;
    xhigh) printf '5\n' ;;
    *)
      echo "invalid thinking level: $1" >&2
      return 1
      ;;
  esac
}

thinking_level_from_rank() {
  case "$1" in
    0) printf 'off\n' ;;
    1) printf 'minimal\n' ;;
    2) printf 'low\n' ;;
    3) printf 'medium\n' ;;
    4) printf 'high\n' ;;
    5) printf 'xhigh\n' ;;
    *)
      echo "invalid thinking rank: $1" >&2
      return 1
      ;;
  esac
}

thinking_level_max() {
  local left right left_rank right_rank
  left="$1"
  right="$2"
  left_rank="$(thinking_level_rank "$left")"
  right_rank="$(thinking_level_rank "$right")"

  if (( left_rank >= right_rank )); then
    printf '%s\n' "$left"
  else
    printf '%s\n' "$right"
  fi
}

thinking_level_min() {
  local left right left_rank right_rank
  left="$1"
  right="$2"
  left_rank="$(thinking_level_rank "$left")"
  right_rank="$(thinking_level_rank "$right")"

  if (( left_rank <= right_rank )); then
    printf '%s\n' "$left"
  else
    printf '%s\n' "$right"
  fi
}

role_default_thinking() {
  case "$1" in
    reviewer|refiner)
      printf 'xhigh\n'
      ;;
    manager|planner|recovery)
      printf 'high\n'
      ;;
    *)
      printf 'medium\n'
      ;;
  esac
}

role_maximum_thinking() {
  case "$1" in
    reviewer|refiner)
      printf 'xhigh\n'
      ;;
    *)
      printf 'high\n'
      ;;
  esac
}

effective_role_thinking() {
  local role ticket explicit_thinking ticket_minimum role_default role_maximum selected
  role="$1"
  ticket="${2:-}"
  explicit_thinking="${3:-}"
  ticket_minimum="off"

  if [[ -n "$ticket" && -f "$ticket" ]]; then
    ticket_minimum="$(ticket_minimum_thinking_from_file "$ticket")"
    ticket_minimum="${ticket_minimum:-off}"
  fi

  if ! valid_thinking_level "$ticket_minimum"; then
    echo "invalid minimum_thinking in $ticket: $ticket_minimum" >&2
    return 1
  fi

  role_default="$(role_default_thinking "$role")"
  role_maximum="$(role_maximum_thinking "$role")"
  selected="$role_default"

  if [[ -n "$explicit_thinking" ]]; then
    if ! valid_thinking_level "$explicit_thinking"; then
      echo "invalid thinking override: $explicit_thinking" >&2
      return 1
    fi

    selected="$explicit_thinking"
  fi

  selected="$(thinking_level_max "$selected" "$ticket_minimum")"
  thinking_level_min "$selected" "$role_maximum"
}

kanban_pi_primary_provider() {
  printf '%s\n' "${PI_KANBAN_PRIMARY_PROVIDER:-openai-codex}"
}

kanban_pi_fallback_provider() {
  printf '%s\n' "${PI_KANBAN_FALLBACK_PROVIDER:-openai}"
}

kanban_pi_default_model() {
  printf '%s\n' "${PI_KANBAN_DEFAULT_MODEL:-gpt-5.4}"
}

latest_checkpoint_ref() {
  if git rev-parse -q --verify refs/tags/kanban/last-known-good >/dev/null 2>&1; then
    printf '%s\n' 'kanban/last-known-good'
    return 0
  fi

  git for-each-ref --sort=-creatordate --format='%(refname:short)' 'refs/tags/kanban/*' \
    | grep -v '^kanban/last-known-good$' \
    | head -n 1
}

reset_manager_health_state() {
  rm -f \
    "$STATE_DIR/manager-health.env" \
    "$STATE_DIR/manager-health-output.txt" \
    "$STATE_DIR/manager-tail.txt" \
    "$STATE_DIR/manager-tail-normalized.txt"
}

manager_nudge_state_file() {
  printf '%s/manager-nudge.env\n' "$STATE_DIR"
}

manager_nudge_due() {
  local cooldown_seconds state_file now last_nudged_at
  cooldown_seconds="$1"
  state_file="$(manager_nudge_state_file)"
  now="$(date +%s)"
  last_nudged_at=""

  if [[ -f "$state_file" ]]; then
    # shellcheck disable=SC1090
    source "$state_file"
  fi

  if [[ -z "${last_nudged_at:-}" ]]; then
    return 0
  fi

  (( now - last_nudged_at >= cooldown_seconds ))
}

seconds_until_manager_nudge() {
  local cooldown_seconds state_file now last_nudged_at elapsed remaining
  cooldown_seconds="$1"
  state_file="$(manager_nudge_state_file)"
  now="$(date +%s)"
  last_nudged_at=""

  if [[ -f "$state_file" ]]; then
    # shellcheck disable=SC1090
    source "$state_file"
  fi

  if [[ -z "${last_nudged_at:-}" ]]; then
    printf '0\n'
    return 0
  fi

  elapsed=$(( now - last_nudged_at ))
  remaining=$(( cooldown_seconds - elapsed ))

  if (( remaining < 0 )); then
    remaining=0
  fi

  printf '%s\n' "$remaining"
}

record_manager_nudge() {
  local reason state_file now
  reason="${1:-periodic-healthcheck}"
  state_file="$(manager_nudge_state_file)"
  now="$(date +%s)"

  {
    printf 'last_nudged_at=%q\n' "$now"
    printf 'last_nudge_reason=%q\n' "$reason"
  } > "$state_file"
}

window_role_activity_snapshot_file() {
  printf '%s/window-role-activity.tsv\n' "$STATE_DIR"
}

window_role_idle_state_file() {
  printf '%s/window-role-idle.env\n' "$STATE_DIR"
}

reset_window_role_activity_state() {
  rm -f "$(window_role_activity_snapshot_file)" "$(window_role_idle_state_file)"
}

capture_window_role_activity() {
  local window_id backbone_pane_id backbone_pane_title pane_id pane_dead history_size pane_title
  window_id="$(tmux_target_window_id)"
  source_backbone_env
  backbone_pane_id="${KANBAN_TMUX_BACKBONE_PANE_ID:-}"
  backbone_pane_title="$(backbone_title)"

  while IFS=$'\t' read -r pane_id pane_dead history_size pane_title; do
    if [[ "$pane_dead" == "0" && "$pane_id" != "$backbone_pane_id" && "$pane_title" == "$PROJECT_NAME:"* && "$pane_title" != "$backbone_pane_title" ]]; then
      printf '%s\t%s\n' "$pane_id" "$history_size"
    fi
  done < <(tmux list-panes -t "$window_id" -F $'#{pane_id}\t#{pane_dead}\t#{history_size}\t#{pane_title}')
}

window_role_panes_all_idle() {
  local snapshot_file current_file current_count previous_count pane_id history_size all_idle
  snapshot_file="$(window_role_activity_snapshot_file)"
  current_file="$(mktemp)"
  capture_window_role_activity > "$current_file"

  if [[ ! -s "$current_file" ]]; then
    mv "$current_file" "$snapshot_file"
    return 1
  fi

  all_idle=1
  if [[ ! -f "$snapshot_file" ]]; then
    all_idle=0
  else
    current_count="$(wc -l < "$current_file" | tr -d ' ')"
    previous_count="$(wc -l < "$snapshot_file" | tr -d ' ')"

    if [[ "$current_count" != "$previous_count" ]]; then
      all_idle=0
    else
      while IFS=$'\t' read -r pane_id history_size; do
        if ! grep -Fqx "$pane_id"$'\t'"$history_size" "$snapshot_file"; then
          all_idle=0
          break
        fi
      done < "$current_file"
    fi
  fi

  mv "$current_file" "$snapshot_file"
  (( all_idle == 1 ))
}

window_role_idle_latched() {
  local state_file all_roles_idle_latched
  state_file="$(window_role_idle_state_file)"
  all_roles_idle_latched=0

  if [[ -f "$state_file" ]]; then
    # shellcheck disable=SC1090
    source "$state_file"
  fi

  [[ "${all_roles_idle_latched:-0}" == "1" ]]
}

set_window_role_idle_latch() {
  printf 'all_roles_idle_latched=%q\n' "${1:-0}" > "$(window_role_idle_state_file)"
}

ensure_single_backbone_pane() {
  local current_pane_id window_id pane_id pane_title title
  current_pane_id="$1"
  window_id="$(tmux_target_window_id)"
  title="$(backbone_title)"

  while IFS=$'\t' read -r pane_id pane_title; do
    if [[ "$pane_title" == "$title" && "$pane_id" != "$current_pane_id" ]] && pane_exists "$pane_id"; then
      tmux kill-pane -t "$pane_id"
    fi
  done < <(tmux list-panes -t "$window_id" -F $'#{pane_id}\t#{pane_title}')

  set_pane_title "$current_pane_id" "$title"
}

run_with_timeout() {
  local timeout_seconds pid watchdog status
  timeout_seconds="$1"
  shift

  "$@" &
  pid=$!

  (
    sleep "$timeout_seconds"
    kill -TERM "$pid" 2>/dev/null || true
    sleep 2
    kill -KILL "$pid" 2>/dev/null || true
  ) &
  watchdog=$!

  status=0
  wait "$pid" || status=$?
  kill -TERM "$watchdog" 2>/dev/null || true
  wait "$watchdog" 2>/dev/null || true

  return "$status"
}

kanban_slugify() {
  local value slug
  value="$1"
  slug="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"

  if [[ -z "$slug" ]]; then
    slug="ticket"
  fi

  printf '%s\n' "$slug"
}

kanban_markdown_title() {
  awk '/^# / { sub(/^# /, "", $0); print; exit }' "$1"
}

kanban_has_ticket_files() {
  local kanban_root
  kanban_root="$1"

  find \
    "$kanban_root/0-open" \
    "$kanban_root/1-to_refine" \
    "$kanban_root/2-planned" \
    "$kanban_root/3-in_progress" \
    "$kanban_root/4-in_review" \
    "$kanban_root/5-done" \
    -maxdepth 1 -type f ! -name '.gitkeep' -print -quit | grep -q .
}

kanban_next_ticket_id_for_dir() {
  local kanban_root max_id=0 file ticket_id ticket_number
  kanban_root="$1"

  while IFS= read -r -d '' file; do
    ticket_id="$(ticket_id_from_file "$file")"

    if [[ "$ticket_id" =~ ^KB-([0-9]+)$ ]]; then
      ticket_number=$((10#${BASH_REMATCH[1]}))
      if (( ticket_number > max_id )); then
        max_id=$ticket_number
      fi
    fi
  done < <(
    find \
      "$kanban_root/0-open" \
      "$kanban_root/1-to_refine" \
      "$kanban_root/2-planned" \
      "$kanban_root/3-in_progress" \
      "$kanban_root/4-in_review" \
      "$kanban_root/5-done" \
      -maxdepth 1 -type f -name '*.md' -print0 2>/dev/null
  )

  printf 'KB-%04d\n' "$((max_id + 1))"
}

kanban_main() {
  local subcommand subcommand_path

  if [[ $# -eq 0 ]]; then
    kanban_usage
    exit 0
  fi

  case "$1" in
    -h|--help)
      kanban_usage
      exit 0
      ;;
    help)
      if [[ $# -eq 1 ]]; then
        kanban_usage
        exit 0
      fi

      subcommand="$2"
      shift 2
      subcommand_path="$(kanban_subcommand_path "$subcommand")" || die "unknown kanban subcommand: $subcommand"
      exec "$subcommand_path" --help "$@"
      ;;
    *)
      subcommand="$1"
      shift
      subcommand_path="$(kanban_subcommand_path "$subcommand")" || die "unknown kanban subcommand: $subcommand"
      exec "$subcommand_path" "$@"
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  kanban_main "$@"
fi
