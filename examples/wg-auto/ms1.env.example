# Copy this file outside the repository, for example to:
#   ~/.wg-auto/ms1.env
#
# Do not store real Home Assistant tokens in this Git repository.
# Prefer the macOS Keychain instead:
#
#   security add-generic-password -U -a "$USER" -s wg-auto-home-assistant -w '<LONG_LIVED_ACCESS_TOKEN>'
#
# The LaunchAgent in this repo runs on every machine that installs dotfiles LaunchAgents,
# but the script exits immediately unless the hostname matches WG_AUTO_EXPECT_HOSTNAME.

WG_AUTO_EXPECT_HOSTNAME=ms1
WG_AUTO_TUNNEL=ms1
WG_AUTO_IDLE_THRESHOLD_SECONDS=600
WG_AUTO_HOME_ACTIVE_THRESHOLD_SECONDS=120
WG_AUTO_ENABLE_DISCONNECT=0

# Home Assistant REST API base URL, without a trailing slash.
HA_URL=https://homeassistant.example.com

# Recommended: expose a simple helper boolean in Home Assistant.
# Example meanings:
#   on  = you are away
#   off = you are home
HA_ENTITY_ID=input_boolean.owner_away
HA_AWAY_STATES=on,away,not_home
HA_HOME_STATES=off,home

# If you read person.<name> directly and want any non-home state to count as away,
# set this to 1.
WG_AUTO_TREAT_OTHER_STATES_AS_AWAY=0

# Keychain lookup defaults. Usually you do not need to change these.
HA_TOKEN_KEYCHAIN_SERVICE=wg-auto-home-assistant
HA_TOKEN_KEYCHAIN_ACCOUNT=$USER

# Alternative to Keychain, still outside the repo:
# HA_TOKEN_FILE=$HOME/.wg-auto/home-assistant.token
#
# Least recommended option because it leaves the token in plaintext in your shell environment:
# HA_TOKEN=...
